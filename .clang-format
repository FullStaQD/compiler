BasedOnStyle: LLVM
ColumnLimit: 120
# Handling of include blocks must be consistent with clang-tidy(llvm-include-order).
# See also: https://llvm.org/docs/CodingStandards.html#include-style
IncludeBlocks: Regroup
IncludeCategories:
  # Our Headers
  - Regex: '^"qcc/'
    Priority: 1
  # LLVM Subproject Headers (MLIR)
  - Regex: '^"mlir/'
    Priority: 2
  # LLVM Subproject Headers (LLVM)
  - Regex: '^"llvm/'
    Priority: 3
  # System Headers
  - Regex: "^<.*>"
    Priority: 4
PointerAlignment: Left
Standard: c++20
