{
  "author": {
    "name": "FullStaQD Project",
    "years": [2026]
  },
  "force_author": true,
  "force_license": true,
  "custom_license": "SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception",
  "title": "filename",
  "include": ["**/*"],
  "style_override_for_suffix": {
    ".cpp": "SLASH_STYLE",
    ".h": "SLASH_STYLE",
    ".in": "POUND_STYLE",
    ".mlir": "SLASH_STYLE",
    ".td": "SLASH_STYLE"
  },
  "exclude": [
    "^\\.[^/]+",
    "/\\.[^/]+",
    ".*\\.json",
    ".*\\.md",
    "CMakeLists.txt",
    "(^|/)LICENSE$"
  ]
}
