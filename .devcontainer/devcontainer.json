{
  "name": "FullStaQD Compiler",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "postCreateCommand": "prek install",
  "remoteEnv": {
    "UV_PYTHON": "3.14"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "llvm-vs-code-extensions.vscode-clangd",
        "llvm-vs-code-extensions.vscode-mlir",
        "ms-vscode.cmake-tools"
      ],
      "settings": {
        "clangd.arguments": [
          "--compile-commands-dir=${workspaceFolder}/build/dev"
        ],
        "clangd.path": "clangd"
      }
    }
  },
  "mounts": [
    {
      "source": "${localEnv:QCC_PROJECT_DEVCONTAINER_CUSTOM_MOUNT:./.devcontainer/custom}",
      "target": "/home/vscode/external",
      "type": "bind"
    }
  ]
}
