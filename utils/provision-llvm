#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<EOF
Usage: ${0##*/} [LLVM_DIR]

Clone llvm-project at the pinned base revision and apply the qisa patches.

Arguments:
  LLVM_DIR   Directory to clone llvm-project into.
             Defaults to \$HOME/external/llvm-project-patched.
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

# Anchor all repo-relative paths to the repo root, resolved from this script's
# own location, so the script works regardless of the current directory.
SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
REPO_ROOT=$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel)

LLVM_SRC="$REPO_ROOT/third-party/llvm"
BASE_REV=$(cat "$LLVM_SRC/base.rev")
LLVM_DIR="${1:-$HOME/external/llvm-project-patched}"

if [[ -d "$LLVM_DIR/.git" ]]; then
  echo "Repo already cloned at $LLVM_DIR, skipping clone."
else
  git clone https://github.com/llvm/llvm-project.git "$LLVM_DIR" \
    --filter=blob:none
fi

cd "$LLVM_DIR"

PATCHES=("$LLVM_SRC"/patches/qisa/*.patch)

# Recover from a previous run whose `git am` was interrupted; otherwise the
# checkout below would fail with "you are in the middle of an am session".
if [[ -d "$(git rev-parse --git-path rebase-apply)" ]]; then
  echo "Found an interrupted git am session, aborting it."
  git am --abort
fi

# Fast path: if every patch already reverse-applies, it is present in the tree,
# so there is nothing to do.
all_applied=true
for p in "${PATCHES[@]}"; do
  if ! git apply --reverse --check "$p" 2>/dev/null; then
    all_applied=false
    break
  fi
done

if $all_applied; then
  echo "Patches already applied; nothing to do."
  exit 0
fi

# Rebuild from the pinned base: -f discards any partial/leftover state and drops
# prior patch commits, so `git am` always applies onto a clean base.
git checkout -f "$BASE_REV"

for p in "${PATCHES[@]}"; do
  git am "$p"
done
